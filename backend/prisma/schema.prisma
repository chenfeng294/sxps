generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id          String   @id @default(cuid())
  name        String
  domain      String?
  config      Json
  status      String   @default("ACTIVE")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  users       User[]
  customers   Customer[]
  products    Product[]
  orders      Order[]
  suppliers   Supplier[]
}

model User {
  id          String   @id @default(cuid())
  tenantId    String
  username    String
  password    String
  name        String
  email       String?
  phone       String?
  roleId      String
  role        Role
  status      String   @default("ACTIVE")
  lastLogin   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model Role {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  code        String
  description String?
  permissions Json
  users       User[]
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Customer {
  id              String      @id @default(cuid())
  tenantId        String
  name            String
  level           String      @default("NORMAL")
  contact         String
  phone           String
  email           String?
  address         String?
  settlementType  String      @default("MONTHLY")
  creditLimit     Decimal     @db.Decimal(12,2)
  creditUsed      Decimal     @db.Decimal(12,2) @default(0)
  status          String      @default("ACTIVE")
  tenant          Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  addresses       CustomerAddress[]
  orders          Order[]
  bills           SettlementBill[]
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

model CustomerAddress {
  id          String   @id @default(cuid())
  customerId  String
  address     String
  contact     String?
  phone       String?
  isDefault   Boolean  @default(false)
  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Category {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  parentId    String?
  sortOrder   Int      @default(0)
  parent      Category? @relation("Categories", fields: [parentId], references: [id])
  children    Category[] @relation("Categories")
  products    Product[]
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Product {
  id             String     @id @default(cuid())
  tenantId       String
  name           String
  aliasNames     Json?
  categoryId     String
  category       Category
  sku            String?
  barcode        String?
  unitId         String
  secondaryUnitId String?
  unitRatio      Decimal    @db.Decimal(10,2) @default(1)
  spec           String?
  imageUrl       String?
  status         String     @default("ACTIVE")
  attributes     Json?
  supplierId     String?
  taxRate        Decimal    @db.Decimal(5,2) @default(0)
  tenant         Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  supplier       Supplier?  @relation(fields: [supplierId], references: [id])
  prices         ProductPrice[]
  orderItems     OrderItem[]
  purchaseItems  PurchaseItem[]
  inventory      Inventory[]
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
}

model ProductPrice {
  id          String   @id @default(cuid())
  tenantId    String
  productId   String
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  customerId  String?
  priceType   String   @default("NORMAL")
  price       Decimal  @db.Decimal(10,2)
  validFrom   DateTime?
  validTo     DateTime?
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Unit {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  type        String
  sortOrder   Int      @default(0)
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Supplier {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  contact     String
  phone       String
  address     String?
  email       String?
  qualification String?
  status      String   @default("ACTIVE")
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  products    Product[]
  orders      PurchaseOrder[]
  bills       SettlementBill[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Order {
  id              String     @id @default(cuid())
  orderNo         String
  tenantId        String
  customerId      String
  customer        Customer   @relation(fields: [customerId], references: [id], onDelete: Cascade)
  status          String     @default("PENDING")
  totalAmount     Decimal    @db.Decimal(12,2)
  deliveryDate    DateTime
  deliveryAddressId String?
  remark          String?
  createdBy       String
  tenant          Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  items           OrderItem[]
  sortingTask     SortingTask?
  deliveryTask    DeliveryTask?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
}

model OrderItem {
  id          String   @id @default(cuid())
  orderId     String
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   String
  productName String
  product     Product  @relation(fields: [productId], references: [id])
  quantity    Decimal  @db.Decimal(10,2)
  unit        String
  unitPrice   Decimal  @db.Decimal(10,2)
  amount      Decimal  @db.Decimal(12,2)
  sortedQty   Decimal  @db.Decimal(10,2) @default(0)
  deliveredQty Decimal @db.Decimal(10,2) @default(0)
  remark      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PurchaseOrder {
  id          String   @id @default(cuid())
  poNo        String
  tenantId    String
  supplierId  String
  supplier    Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  status      String   @default("PENDING")
  totalAmount Decimal  @db.Decimal(12,2)
  expectedDate DateTime
  remark      String?
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  items       PurchaseItem[]
  inboundOrders InboundOrder[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PurchaseItem {
  id          String   @id @default(cuid())
  purchaseOrderId String
  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  productId   String
  product     Product  @relation(fields: [productId], references: [id])
  quantity    Decimal  @db.Decimal(10,2)
  unitPrice   Decimal  @db.Decimal(10,2)
  actualPrice Decimal? @db.Decimal(10,2)
  receivedQty Decimal  @db.Decimal(10,2) @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Warehouse {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  address     String?
  type        String
  status      String   @default("ACTIVE")
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  inventory   Inventory[]
  inboundOrders InboundOrder[]
  outboundOrders OutboundOrder[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Inventory {
  id          String   @id @default(cuid())
  tenantId    String
  productId   String
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  batchNo     String?
  quantity    Decimal  @db.Decimal(12,2)
  availableQty Decimal @db.Decimal(12,2)
  unitCost    Decimal? @db.Decimal(10,2)
  location    String?
  productionDate DateTime?
  expiryDate  DateTime?
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model InboundOrder {
  id          String   @id @default(cuid())
  ibNo        String
  tenantId    String
  type        String
  status      String   @default("PENDING")
  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  purchaseOrderId String?
  purchaseOrder PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id])
  totalQty    Decimal  @db.Decimal(12,2)
  totalAmount Decimal  @db.Decimal(12,2)
  remark      String?
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  items       InboundItem[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model InboundItem {
  id          String   @id @default(cuid())
  inboundOrderId String
  inboundOrder InboundOrder @relation(fields: [inboundOrderId], references: [id], onDelete: Cascade)
  productId   String
  product     Product  @relation(fields: [productId], references: [id])
  quantity    Decimal  @db.Decimal(10,2)
  unitPrice   Decimal  @db.Decimal(10,2)
  actualQty   Decimal? @db.Decimal(10,2)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model OutboundOrder {
  id          String   @id @default(cuid())
  obNo        String
  tenantId    String
  type        String
  status      String   @default("PENDING")
  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  totalQty    Decimal  @db.Decimal(12,2)
  remark      String?
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  items       OutboundItem[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model OutboundItem {
  id          String   @id @default(cuid())
  outboundOrderId String
  outboundOrder OutboundOrder @relation(fields: [outboundOrderId], references: [id], onDelete: Cascade)
  productId   String
  product     Product  @relation(fields: [productId], references: [id])
  quantity    Decimal  @db.Decimal(10,2)
  actualQty   Decimal? @db.Decimal(10,2)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SortingTask {
  id          String   @id @default(cuid())
  tenantId    String
  orderId     String
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  status      String   @default("PENDING")
  mode        String
  assigneeId  String?
  progress    Int      @default(0)
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  items       SortingItem[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SortingItem {
  id          String   @id @default(cuid())
  sortingTaskId String
  sortingTask SortingTask @relation(fields: [sortingTaskId], references: [id], onDelete: Cascade)
  productId   String
  product     Product  @relation(fields: [productId], references: [id])
  quantity    Decimal  @db.Decimal(10,2)
  sortedQty   Decimal  @db.Decimal(10,2) @default(0)
  status      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Driver {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  phone       String
  vehicleNo   String?
  license     String?
  status      String   @default("ACTIVE")
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tasks       DeliveryTask[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Route {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  description String?
  stops       Json?
  sortOrder   Int      @default(0)
  status      String   @default("ACTIVE")
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tasks       DeliveryTask[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model DeliveryTask {
  id          String   @id @default(cuid())
  tenantId    String
  orderId     String
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  driverId    String?
  driver      Driver?  @relation(fields: [driverId], references: [id])
  routeId     String?
  route       Route?   @relation(fields: [routeId], references: [id])
  status      String   @default("PENDING")
  expectedTime DateTime?
  actualTime  DateTime?
  signature   String?
  photoUrl    String?
  remark      String?
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SettlementBill {
  id          String   @id @default(cuid())
  billNo      String
  tenantId    String
  type        String
  partyId     String
  period      String
  totalAmount Decimal  @db.Decimal(12,2)
  paidAmount  Decimal  @db.Decimal(12,2) @default(0)
  status      String   @default("PENDING")
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  payments    PaymentRecord[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PaymentRecord {
  id            String   @id @default(cuid())
  billId        String
  bill          SettlementBill @relation(fields: [billId], references: [id], onDelete: Cascade)
  amount        Decimal  @db.Decimal(12,2)
  method        String
  status        String
  remark        String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
